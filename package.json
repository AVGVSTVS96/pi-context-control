{
    "name": "pi-context-control",
    "version": "0.1.0",
    "description": "Interactive context window manager for pi: see per-message token usage, mask anything in or out of context, and swap spans for compact LLM summaries.",
    "type": "module",
    "license": "MIT",
    "author": "Bassim Shahidy",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AVGVSTVS96/pi-context-control.git"
    },
    "homepage": "https://github.com/AVGVSTVS96/pi-context-control#readme",
    "bugs": "https://github.com/AVGVSTVS96/pi-context-control/issues",
    "files": [
        "extensions",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "tsx test/logic.test.ts && tsx test/panel.test.ts"
    },
    "keywords": [
        "pi-package"
    ],
    "pi": {
        "extensions": [
            "./extensions"
        ]
    },
    "peerDependencies": {
        "@earendil-works/pi-ai": "*",
        "@earendil-works/pi-coding-agent": "*",
        "@earendil-works/pi-tui": "*"
    },
    "devDependencies": {
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    }
}
