{
    "name": "pi-context-control",
    "version": "0.1.0",
    "description": "Interactive context window manager for pi: see per-message token usage and mask anything in/out of context at will.",
    "type": "module",
    "license": "MIT",
    "files": [
        "extensions",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit"
